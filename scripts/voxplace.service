[Unit]
Description=VoxPlace Game Server
After=network.target

[Service]
Type=simple
ExecStart=env VOXPLACE_PROFILE_WORKERS=1 VOXPLACE_ADMIN_USERS="Admin" /root/VoxPlace/build/VoxPlaceServer --port 28713
WorkingDirectory=/root/VoxPlace
Nice=-20
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
