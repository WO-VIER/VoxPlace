{
    // Utilisez IntelliSense pour en savoir plus sur les attributs possibles.
    // Pointez pour afficher la description des attributs existants.
    // Pour plus d'informations, visitez : https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C/C++: Lancer (gdb) - Native",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/VoxPlace",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "build: native",
            "setupCommands": [
                {
                    "description": "Activer l'impression en mode Pretty pour gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Définir la version désassemblage sur Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "C/C++: Lancer (gdb) - Native (ASan)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_asan/VoxPlace",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "ASAN_OPTIONS",
                    "value": "detect_leaks=1:halt_on_error=1:abort_on_error=1"
                },
                {
                    "name": "LSAN_OPTIONS",
                    "value": "suppressions=${workspaceFolder}/scripts/lsan_suppressions.txt:print_suppressions=0"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "build: native (ASan)",
            "setupCommands": [
                {
                    "description": "Activer l'impression en mode Pretty pour gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Définir la version désassemblage sur Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Demande à GDB de ne pas arrêter le programme sur ASAN SIGSEGV non fatal",
                    "text": "handle SIGSEGV nostop noprint pass",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Chrome: Lancer (WASM)",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "serve: wasm",
            "url": "http://localhost:8000/VoxPlace.html",
            "webRoot": "${workspaceFolder}/build_wasm",
            "sourceMaps": true
        }
    ]
}
